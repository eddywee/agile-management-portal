{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HELIX Agile Portal",
  "version": "0.1.1",
  "identifier": "com.mercedes-benz.helix-agile-portal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "HELIX Agile Portal — SAFe Investment Tracker",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://git.swf.i.mercedes-benz.com/api/v4/projects/wallnee%2Fhelix-agile-portal/packages/generic/helix-agile-portal-update/latest/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDRTVFQThGOTUyRTM1OEMKUldTTU5TNlZqK3JsVE0yeHU5YkM3dVNWaXNmRG1kc1ZlN2FBMzRZY29wUkRFZ1J4RzQ5TGVxR3YK"
    }
  }
}
